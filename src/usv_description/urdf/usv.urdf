<?xml version="1.0" ?>
<robot name="my_robot">
    <webots>
        <plugin type="usv_simulation.webots_interface.WebotsInterface" />
        <immersionProperties>
            <ImmersionProperties>
                <fluidName>fluid</fluidName>
                <dragForceCoefficients>0.5 0.5 0.1</dragForceCoefficients>
                <viscousResistanceForceCoefficient>3</viscousResistanceForceCoefficient>
                <viscousResistanceTorqueCoefficient>2000</viscousResistanceTorqueCoefficient>
            </ImmersionProperties>
        </immersionProperties>
    </webots>
    
    <!-- Base link of the boat -->
    <link name="base_link">
        <visual>
            <origin xyz="0 0 0.0" rpy="0 1.5708 1.5708"/>
            <geometry>
                <mesh filename="package://usv_description/meshes/blueboat_visual.obj"/>
            </geometry>
        </visual>
        <collision>
            <origin xyz="0 0 -0.5" rpy="0 0 0"/>
            <geometry>
                <box size="1.2 0.75 0.4"/>
            </geometry>
        </collision>
    </link>

    <!-- Wings are now part of the main hull mesh -->>

    <!-- Lidar (Placed high up and forward, clean orientation) -->
    <link name="laser_link">
    </link>

    <joint name="laser_joint" type="fixed">
        <parent link="base_link"/>
        <child link="laser_link"/>
        <origin xyz="0 0 0.0" rpy="0 0 0"/>
    </joint>

    <!-- IMU & GPS -->
    <link name="imu_link">
    </link>

    <joint name="imu_joint" type="fixed">
        <parent link="base_link"/>
        <child link="imu_link"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>

    <!-- Propellers (Offset back and lateral, pushing forward +X) -->
    <link name="left_prop">
    </link>

    <joint name="left_prop_joint" type="continuous">
        <parent link="base_link"/>
        <child link="left_prop"/>
        <origin xyz="-0.45 0.25 0.005" rpy="0 0 0"/>
        <axis xyz="1 0 0"/>
    </joint>

    <link name="right_prop">
    </link>

    <joint name="right_prop_joint" type="continuous">
        <parent link="base_link"/>
        <child link="right_prop"/>
        <origin xyz="-0.45 -0.25 0.005" rpy="0 0 0"/>
        <axis xyz="1 0 0"/>
    </joint>

</robot>